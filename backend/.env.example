# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Farmer-to-Home API"
DEBUG=False

# ─── Database ──────────────────────────────────────────────────────────────────
# Synchronous URL (used by Alembic migrations with psycopg2)
DATABASE_URL=postgresql://fth_user:fth_password@localhost:5433/farmer_to_home

# Async URL (used by SQLAlchemy async engine with asyncpg)
ASYNC_DATABASE_URL=postgresql+asyncpg://fth_user:fth_password@localhost:5433/farmer_to_home

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-super-secret-key-minimum-32-characters-change-in-production
ADMIN_SECRET_KEY=your-admin-secret-key-minimum-32-characters-change-in-production
ALGORITHM=HS256

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ─── AWS S3 (for file uploads) ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET_NAME=farmer-to-home-bucket
AWS_REGION=ap-south-1

# ─── Razorpay (for payments) ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Platform Settings ────────────────────────────────────────────────────────
PLATFORM_COMMISSION_PERCENT=5.0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","https://farmertohome.in"]

# ─── Optional: SMS Provider (MSG91 example) ───────────────────────────────────
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_TEMPLATE_ID=your-template-id

# ─── Optional: Firebase (for push notifications) ──────────────────────────────
# FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
